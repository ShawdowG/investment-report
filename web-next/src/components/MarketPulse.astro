---
const { regime = '', pulse = [] } = Astro.props;
---
<section class="market-pulse">
  <h2>Market Pulse</h2>
  <p><strong>Regime:</strong> {regime || 'n/a'}</p>
  <ul>
    {(pulse.length ? pulse : ['Awaiting pulse update.']).map((line) => <li>{line.replace(/^-\s*/, '')}</li>)}
  </ul>
</section>

<style>
  .market-pulse { border:1px solid #e5e7eb; border-radius:10px; padding:1rem; background:#fff; }
  h2 { margin:.2rem 0 .5rem; }
  ul { margin:.2rem 0 0 1.1rem; line-height:1.5; }
</style>
