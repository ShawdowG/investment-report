---
const { movers = [], collapsed = false, sortBy = 'ticker' } = Astro.props;

const list = Array.isArray(movers) ? [...movers] : [];
const key = sortBy === 'pct' ? 'pct' : 'ticker';
list.sort((a, b) => {
  if (key === 'pct') {
    const av = typeof a?.pct === 'number' ? a.pct : -9999;
    const bv = typeof b?.pct === 'number' ? b.pct : -9999;
    return bv - av;
  }
  return String(a?.ticker ?? '').localeCompare(String(b?.ticker ?? ''));
});
---
<section class="ticker-table">
  <details open={!collapsed}>
    <summary><strong>Ticker Table</strong> ({list.length})</summary>
    <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Ticker</th><th>Name</th><th class="num">Price</th><th class="num">Δ$</th><th>Move</th></tr>
      </thead>
      <tbody>
        {list.map((r) => {
          const pct = typeof r.pct === 'number' ? r.pct : null;
          const tone = pct === null ? '' : pct < 0 ? 'neg' : pct > 0 ? 'pos' : 'flat';
          const arrow = pct === null ? '•' : pct < 0 ? '↓' : pct > 0 ? '↑' : '→';
          const move = pct === null ? '—' : pct > 0 ? `+${pct.toFixed(2)}%` : pct < 0 ? `${pct.toFixed(2)}%` : '+0.00%';
          return (
            <tr>
              <td>{r.ticker}</td>
              <td>{r.name}</td>
              <td class="num">{r.price}</td>
              <td class={`num ${tone}`}>{r.change ?? '—'}</td>
              <td class={tone}>{`${arrow} ${move}`}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
    </div>
  </details>
</section>

<style>
  details { border:1px solid #e5e7eb; border-radius:10px; padding:.7rem 1rem; background:#fff; }
  summary { cursor:pointer; margin-bottom:.6rem; }
  .table-wrap { max-height: 540px; overflow:auto; border:1px solid #f0f2f4; border-radius:8px; }
  table { width:100%; border-collapse:collapse; font-size:.9rem; }
  th,td { text-align:left; border-bottom:1px solid #f0f2f4; padding:.5rem .45rem; }
  thead th { position:sticky; top:0; background:#fff; z-index:1; }
  .num { text-align:right; font-variant-numeric: tabular-nums; }
  .pos { color:#067647; }
  .neg { color:#b42318; }
  .flat { color:#475467; }
</style>
