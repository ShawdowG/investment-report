---
const { currentPath = '/' } = Astro.props;
const links = [
  { href: '/', label: 'Main' },
  { href: '/tracker', label: 'Tracker' },
  { href: '/reports', label: 'Reports' },
];
---
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">Investment Report</a>
    <ul class="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} class:list={['nav-link', { active: currentPath === l.href }]}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 1.5rem;
  }
  .nav-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
  }
  .nav-brand {
    font-weight: 600;
    font-size: 0.95rem;
    color: #111;
    text-decoration: none;
  }
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem;
  }
  .nav-link {
    display: block;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9rem;
    color: #555;
    text-decoration: none;
  }
  .nav-link:hover {
    background: #f0f2f4;
    color: #111;
  }
  .nav-link.active {
    color: #067647;
    font-weight: 600;
  }
  @media (max-width: 760px) {
    .nav-brand { font-size: 0.875rem; }
    .nav-link { padding: 0.3rem 0.5rem; font-size: 0.85rem; }
  }
</style>
