---
import TimeRangePicker from './TimeRangePicker.astro';

const { title, date, slot = 'pre-close' } = Astro.props;
---
<header class="header-bar">
  <div>
    <h1>{title}</h1>
    <p class="meta">{date} · {slot}</p>
  </div>
  <TimeRangePicker selected={slot} />
</header>

<style>
  .header-bar { display:flex; justify-content:space-between; align-items:flex-end; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }
  h1 { margin:0; font-size:1.5rem; }
  .meta { margin:.25rem 0 0; color:#555; font-size:.9rem; }
</style>
