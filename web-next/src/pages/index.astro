---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderBar from '../components/HeaderBar.astro';
import MarketPulse from '../components/MarketPulse.astro';
import TakeawayPanel from '../components/TakeawayPanel.astro';
import DiscussionPanel from '../components/DiscussionPanel.astro';
import TickerTable from '../components/TickerTable.astro';
import NewsMoversTable from '../components/NewsMoversTable.astro';
import TacticalQuickPanel from '../components/TacticalQuickPanel.astro';
import { loadSearchIndex } from '../lib/loaders.js';
import { adaptMovers, deriveNewsFromMovers } from '../lib/adapters.js';

const idx = await loadSearchIndex();
const slot = Astro.url.searchParams.get('slot') ?? 'pre-close';
const sort = Astro.url.searchParams.get('sort') ?? 'pct';
const collapsed = Astro.url.searchParams.get('collapsed') === '1';
const latest = idx.items?.find((it) => it.slot === slot) ?? idx.items?.[0];
const adaptedMovers = adaptMovers(latest?.movers ?? [], { sortBy: sort === 'ticker' ? 'ticker' : 'pct', limit: 50 });
const adaptedNews = Array.isArray(latest?.news) && latest.news.length > 0 ? latest.news : deriveNewsFromMovers(adaptedMovers);
---
<BaseLayout title="Investment Report" currentPath="/">
  <HeaderBar title="Investment Report" date={latest?.date ?? 'n/a'} slot={latest?.slot ?? slot} />

  <MarketPulse regime={latest?.regime ?? ''} pulse={latest?.sections?.pulse ?? []} />
  <TakeawayPanel summary={latest?.summary ?? ''} regime={latest?.regime ?? ''} date={latest?.date ?? ''} slot={latest?.slot ?? slot} />
  <DiscussionPanel alpha={latest?.sections?.alpha ?? []} beta={latest?.sections?.beta ?? []} />
  <TacticalQuickPanel beta={latest?.sections?.beta ?? []} discussion={{agreement: '', disagreement: '', resolution: (latest?.sections?.beta ?? [])[2] ?? ''}} regime={latest?.regime ?? ''} />

  <p class="muted">
    Table controls:
    <a href={`/?slot=${latest?.slot ?? slot}&sort=ticker&collapsed=0`}>sort=ticker</a> ·
    <a href={`/?slot=${latest?.slot ?? slot}&sort=pct&collapsed=0`}>sort=pct</a> ·
    <a href={`/?slot=${latest?.slot ?? slot}&sort=${sort}&collapsed=1`}>collapsed</a>
  </p>

  <TickerTable movers={adaptedMovers} sortBy={sort} collapsed={collapsed} />
  <NewsMoversTable movers={adaptMovers(latest?.movers ?? [], { sortBy: 'absPct', limit: 8 })} news={adaptedNews} />
</BaseLayout>
