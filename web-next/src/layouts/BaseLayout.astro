---
const { title = 'Investment Report (Astro Migration)' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      body { font-family: Inter, system-ui, sans-serif; max-width: 980px; margin: 2rem auto; padding: 0 1rem; }
      pre { white-space: pre-wrap; background:#f6f7f9; padding: 1rem; border-radius: 8px; }
      .muted { color:#555; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
